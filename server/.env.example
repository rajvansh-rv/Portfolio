# Server configuration port
PORT=

# Environment mode ('development' or 'production')
NODE_ENV=

# Database connection string (MongoDB URI)
MONGODB_URI=

# Frontend base URL for CORS protection (e.g. your Netlify, Vercel, or custom domain URL)
FRONTEND_URL=

# Nodemailer Gmail SMTP Configurations
# The Gmail address used to authenticate and send the emails
EMAIL_USER=

# The 16-character App Password generated from your Google Account settings
EMAIL_PASS=

# The destination email address where you want to receive the portfolio messages
RECEIVER_EMAIL=
